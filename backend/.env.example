# FinCore - Configuracion de Entorno
# Copiar a .env y configurar valores
#
# ⚠️  IMPORTANTE: En producción, TODOS los secretos deben estar configurados.
#     El sistema NO iniciará sin ellos.

# Application
APP_NAME="FinCore - Sistema Financiero"
# ⚠️  CRÍTICO: DEBUG=false en producción (expone /docs y genera claves temporales)
DEBUG=true

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=finance_system
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# Redis (Sessions & Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================================================
# JWT Security - ⚠️ OBLIGATORIO EN PRODUCCIÓN
# ==========================================================================
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# DEBE tener al menos 32 caracteres
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Tiempo de expiración del token de acceso (recomendado: 15-30 minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA
MFA_ISSUER_NAME=FinCore
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ==========================================================================
# Encryption - ⚠️ OBLIGATORIO EN PRODUCCIÓN
# ==========================================================================
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# Blockchain Wallet Encryption (Fernet/AES-128-CBC)
# CRITICO: Esta clave protege las llaves privadas de wallets custodiales
# En produccion, usar AWS KMS o HashiCorp Vault
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=

# ==========================================================================
# Webhook Security - ⚠️ OBLIGATORIO EN PRODUCCIÓN
# ==========================================================================
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=

# ==========================================================================
# Go Service Security (si se usa el servicio Go)
# ==========================================================================
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# AWS S3 (Document Vault)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=fincore-vault

# Tax API Integration
TAX_API_URL=
TAX_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==================== BLOCKCHAIN ====================
# Network Configuration
BLOCKCHAIN_DEFAULT_NETWORK=polygon
BLOCKCHAIN_OPERATOR_KEY=

# RPC URLs - Production
POLYGON_RPC_URL=https://polygon-rpc.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# RPC URLs - Testnets
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Block Explorer API Keys
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=

# Remittance Contract Address
REMITTANCE_CONTRACT_ADDRESS=

# ==================== COMPLIANCE / PLD ====================
# Chainalysis API - Screening de direcciones blockchain
# Obtener API Key en: https://www.chainalysis.com/
CHAINALYSIS_API_KEY=
CHAINALYSIS_API_URL=https://api.chainalysis.com/api
CHAINALYSIS_KYT_URL=https://api.chainalysis.com/api/kyt/v2
CHAINALYSIS_SANCTIONS_URL=https://api.chainalysis.com/api/sanctions/v1
CHAINALYSIS_TIMEOUT=30

# Elliptic API - Alternativa/Failover
# Obtener API Key en: https://www.elliptic.co/
ELLIPTIC_API_KEY=
ELLIPTIC_API_URL=https://aml-api.elliptic.co/v2

# Screening Thresholds (0-100)
# Auto-aprobar si score <= este valor
SCREENING_AUTO_APPROVE_MAX_SCORE=30
# Requiere revision manual si score >= este valor
SCREENING_REVIEW_MIN_SCORE=31
# Auto-rechazar si score >= este valor
SCREENING_AUTO_REJECT_MIN_SCORE=70
# Bloquear si score >= este valor
SCREENING_BLOCK_MIN_SCORE=90
# Monto USD para activar screening mejorado
SCREENING_ENHANCED_AMOUNT_USD=3000.0
# Monto USD para reporte automatico SAR
SCREENING_AUTO_REPORT_AMOUNT_USD=10000.0

# Compliance Notifications
COMPLIANCE_ALERT_EMAIL=compliance@tuempresa.com
COMPLIANCE_WEBHOOK_URL=

# ==================== STP (SPEI) ====================
# Sistema de Transferencias y Pagos - Pagos SPEI tiempo real
# Documentacion: https://stpmex.com/documentacion

# API URLs (demo vs produccion)
STP_API_URL=https://demo.stpmex.com/speiws/rest
STP_API_URL_PROD=https://prod.stpmex.com/speiws/rest
STP_USE_PRODUCTION=false

# Credenciales de empresa (proporcionadas por STP)
STP_EMPRESA=FINCORE
STP_CLABE_CONCENTRADORA=646180000000000001

# Firma digital (certificado RSA)
# Generar con: openssl genrsa -out stp_private.pem 2048
STP_PRIVATE_KEY_PATH=/path/to/stp_private.pem
STP_PRIVATE_KEY_PASSWORD=

# Webhook
STP_WEBHOOK_SECRET=
STP_TIMEOUT=30

# ==================== BITSO (Exchange Cripto-Fiat) ====================
# Bitso es el exchange de criptomonedas mas grande de LATAM
# Permite conversion USDC <-> MXN y retiros SPEI
# Documentacion API: https://bitso.com/api_info

# Credenciales de API (obtener en Panel de Bitso)
BITSO_API_KEY=
BITSO_API_SECRET=

# Modo de operacion
# false = sandbox/dev (api-dev.bitso.com)
# true = produccion (api.bitso.com)
BITSO_USE_PRODUCTION=false

# URLs de API
BITSO_API_URL=https://api.bitso.com
BITSO_SANDBOX_URL=https://api-dev.bitso.com

# Configuracion de trading
BITSO_DEFAULT_BOOK=usdc_mxn
BITSO_TIMEOUT=30

# Limites de conversion por transaccion
BITSO_MIN_USDC_CONVERSION=1.0
BITSO_MAX_USDC_CONVERSION=50000.0

# Cache de tasas de cambio (segundos)
BITSO_RATE_CACHE_TTL=30

# Webhook para notificaciones (ordenes, retiros, depositos)
BITSO_WEBHOOK_SECRET=
