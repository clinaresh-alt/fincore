# =========================================================
# FINCORE - SMART CONTRACTS ENVIRONMENT CONFIGURATION
# =========================================================
# Copia este archivo a .env y completa los valores

# ---------------------------------------------------------
# BLOCKCHAIN OPERATOR KEY
# ---------------------------------------------------------
# Private key de la wallet que desplegara los contratos
# NUNCA compartas esta clave ni la subas a git
BLOCKCHAIN_OPERATOR_KEY=

# ---------------------------------------------------------
# RPC URLs - MAINNET
# ---------------------------------------------------------
# Obtener en: https://infura.io o https://alchemy.com
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_KEY
ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.infura.io/v3/YOUR_KEY

# ---------------------------------------------------------
# RPC URLs - TESTNET
# ---------------------------------------------------------
POLYGON_AMOY_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_KEY
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# ---------------------------------------------------------
# BLOCK EXPLORER API KEYS
# ---------------------------------------------------------
# Necesarios para verificar contratos en los exploradores
# Polygon: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Ethereum: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Arbitrum: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# Base: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ---------------------------------------------------------
# GAS REPORTER (Opcional)
# ---------------------------------------------------------
# Para reportes de gas en tests
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# =========================================================
# COMANDOS DE DEPLOYMENT
# =========================================================
#
# 1. Instalar dependencias:
#    npm install
#
# 2. Compilar contratos:
#    npx hardhat compile
#
# 3. Ejecutar tests:
#    npx hardhat test
#
# 4. Deploy en testnet (Polygon Amoy):
#    npx hardhat run scripts/deploy.js --network polygonAmoy
#
# 5. Deploy en mainnet (Polygon):
#    npx hardhat run scripts/deploy.js --network polygon
#
# 6. Verificar contratos:
#    npx hardhat run scripts/verify-contracts.js --network polygon
#
# 7. Deploy de token de proyecto:
#    PROJECT_NAME="Mi Proyecto" PROJECT_SYMBOL="MPRJ" TOTAL_SUPPLY=1000000 \
#    npx hardhat run scripts/deploy-token.js --network polygon
#
# =========================================================
