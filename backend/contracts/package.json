{
  "name": "fincore-contracts",
  "version": "1.0.0",
  "description": "Smart Contracts para FinCore - Tokenizacion de Proyectos",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "clean": "hardhat clean",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy.js --network polygonAmoy",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrum",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "verify:amoy": "hardhat run scripts/verify-contracts.js --network polygonAmoy",
    "verify:sepolia": "hardhat run scripts/verify-contracts.js --network sepolia",
    "verify:polygon": "hardhat run scripts/verify-contracts.js --network polygon",
    "verify:arbitrum": "hardhat run scripts/verify-contracts.js --network arbitrum",
    "verify:base": "hardhat run scripts/verify-contracts.js --network base"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.1",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.4"
  },
  "license": "MIT"
}
